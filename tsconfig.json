{
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "lib": [
      "es2023",
      "DOM",
      "DOM.Iterable"
    ],
    "baseUrl": ".",
    "paths": {
      "@huggingface/transformers": [
        "./node_modules/@huggingface/transformers/types/transformers.d.ts"
      ],
      "@Purper": [
        "./node_modules/@reidelsaltres/pureper/src/index.js"
      ],
      "@material-design-icons": [
        "./node_modules/@material-design-icons/*"
      ]
    },
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./out",
    //"resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "sourceMap": true
  },
  "include": [
    "./src",
    "./index.html.ts",
    "./404.html.ts"
  ],
  "exclude": [
    "./test"
  ]
}