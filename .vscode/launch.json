{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "TSX",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "npx",
      "runtimeArgs": [
        "tsx",
        "${file}"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Bullshit",
      "cwd": "${workspaceFolder}",
      "program": "${workspaceFolder}/serve.js",
      "preLaunchTask": "watch",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "serverReadyAction": {
        "pattern": "Server running at (https?://[^\\s]+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      "type": "editor-browser",
      "request": "launch",
      "preLaunchTask": "watch",
      "name": "Watch",
      "url": "http://127.0.0.1:5501",
      "webRoot": "${workspaceFolder}",
    }
  ]
}